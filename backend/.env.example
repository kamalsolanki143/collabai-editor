# CollabAI Editor — Backend Environment Variables
# Copy this file to .env and fill in the values.

# Google Gemini API Key (required for semantic search)
GOOGLE_API_KEY=your_google_api_key_here

# FAISS vector database persistence directory
FAISS_DB_PATH=./faiss_data

# Server port
PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Yjs WebSocket path
YJS_WS_PATH=/yjs

# Indexing debounce delay in seconds
INDEX_DEBOUNCE_SECONDS=2.0

# Chunk size for text splitting
CHUNK_SIZE=500

# Chunk overlap
CHUNK_OVERLAP=50

# Maximum search results
MAX_SEARCH_RESULTS=10

# Rate limit (search requests per minute per client)
SEARCH_RATE_LIMIT=30

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
